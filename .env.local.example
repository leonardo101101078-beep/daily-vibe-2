# Daily-Vibe 2.0 — Copy this file to .env.local and fill in your values.
# Database: run migrations in supabase/migrations/ via Supabase SQL Editor (in order if new). For weekly/every_other_day tasks use 006_task_recurrence_extended.sql.
# ─────────────────────────────────────────────────────
# Supabase — find in: Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────
# Web Push / VAPID Keys
# Generate once with:  npx web-push generate-vapid-keys
#
# IMPORTANT: Back up VAPID_PRIVATE_KEY — it cannot be regenerated.
# If lost, all existing push subscriptions become invalid.
VAPID_SUBJECT=mailto:your-email@example.com
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
# Same as VAPID_PUBLIC_KEY — exposed to the browser for subscription
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ─────────────────────────────────────────────────────
# Cron Secret — protects the /api/push/cron endpoint
# Use any long random string (e.g. openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here
